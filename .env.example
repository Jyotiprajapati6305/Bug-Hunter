# Copy this file to .env and adjust values as needed.
# docker-compose.yml reads these via env_file: .env (falls back to these
# defaults if .env is absent, since docker-compose.yml also hardcodes safe
# local-dev defaults for every variable).

# --- Postgres ---
POSTGRES_USER=bughunter
POSTGRES_PASSWORD=bughunter
POSTGRES_DB=bughunter
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Backend / FastAPI ---
ENVIRONMENT=development
DEBUG=true
DATABASE_URL=postgresql+psycopg2://bughunter:bughunter@postgres:5432/bughunter

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# --- JWT ---
JWT_SECRET_KEY=change_me_to_a_long_random_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
